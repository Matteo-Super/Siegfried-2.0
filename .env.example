# ── Firebase Web config ──
# These are public client-side identifiers. The app ships with the Siegfried
# project values as defaults; override here only if you fork to your own project.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Stripe Payment Links (serverless checkout — no backend needed) ──
# Create these in the Stripe Dashboard → Payment Links. See docs/STRIPE_SETUP.md.
# Set each link's success URL to: https://YOUR_DOMAIN/?purchase=success
VITE_STRIPE_PRODUCT_LINK=
VITE_STRIPE_TIP_CUSTOM_LINK=
# Optional fixed-amount tip links (fall back to the custom link if blank):
VITE_STRIPE_TIP_1=
VITE_STRIPE_TIP_3=
VITE_STRIPE_TIP_5=
VITE_STRIPE_TIP_10=
